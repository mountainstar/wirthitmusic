# Optional: ReCAPTCHA (contact form)
VITE_RECAPTCHA_SITE_KEY=

# Mail API base URL from Terraform output: mail_http_api_url
# Also used for GET {base}/soundcloud/tracks (SoundCloud credentials are server-side in Terraform).
# Example: https://abc123.execute-api.us-east-1.amazonaws.com
VITE_MAIL_API_BASE_URL=

# Optional: /profile — load YouTube uploads from a channel (or a specific playlist).
# Restrict the key in Google Cloud Console to HTTP referrers (your site URL).
# Channel ID from youtube.com/channel/UC… (uploads playlist is derived by replacing UC with UU).
VITE_YOUTUBE_API_KEY=
VITE_YOUTUBE_CHANNEL_ID=
# Example: VITE_YOUTUBE_CHANNEL_ID=UCex7epU9ySQqN5dy34gLz8Q
# VITE_YOUTUBE_PLAYLIST_ID=
